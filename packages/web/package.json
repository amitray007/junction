{
  "name": "@junction/web",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "clean:stale-js": "find src -name '*.js' ! -name 'entry-server.js' ! -name 'entry-client.js' -delete",
    "prebuild": "pnpm run clean:stale-js",
    "build": "vite build",
    "start": "node serve.mjs",
    "typecheck": "tsr generate && tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "exports": {
    "./server": "./serve.mjs"
  },
  "dependencies": {
    "@junction/core": "workspace:*",
    "@junction/platform-orchestration": "workspace:*",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-router": "^1.170.0",
    "@tanstack/react-start": "^1.168.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "neverthrow": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@tanstack/router-cli": "^1.167.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "agentation": "^3.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "^20.10.6",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }

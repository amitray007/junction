{
  "name": "junction-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "license": "AGPL-3.0-only",
  "scripts": {
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run test:ci",
    "quality": "pnpm audit --audit-level=high || true",
    "typecheck": "tsc -b",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:related": "vitest related --run",
    "test:ci": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "lefthook": "^2.1.9",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}

{
  "name": "junction-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run test:ci",
    "typecheck": "test -f tsconfig.json && tsc -b || echo '(no tsconfig project yet — typecheck no-op until increment 1; remove this guard then)'",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:related": "vitest related --run",
    "test:ci": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "lefthook": "^1.13.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
